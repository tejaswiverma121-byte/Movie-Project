<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Movies ADDA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    .fav-badge {
  z-index: 10;
}
    :root {
      --pink: #c93078;
      --pink-dark: #a52260;
      --pink-glow: rgba(201, 48, 120, 0.25);
      --gold: #f5c518;
      --bg: #0d0008;
      --surface: #1a000f;
      --surface2: #220015;
      --border: rgba(220, 80, 140, 0.15);
      --text: #f0e0ea;
      --muted: #804060;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--bg);
      color: var(--text);
      padding-top: 68px;
    }
    .navbar {
      background: rgba(13, 0, 8, 0.96) !important;
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      height: 68px;
    }
    .navbar-brand { display: flex; flex-direction: column; line-height: 1; text-decoration: none; }
    .brand-name { font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: #fff; letter-spacing: 2px; }
    .brand-sub { font-size: 9px; color: var(--pink); letter-spacing: 3px; font-weight: 600; }
    .nav-link { color: var(--muted) !important; font-size: 13px; font-weight: 500; transition: color 0.2s; padding: 0.5rem 1rem !important; }
    .nav-link:hover, .nav-link.active { color: #fff !important; }
    .search-box {
      display: flex; align-items: center;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0 6px 0 14px;
      width: 280px;
    }
    .search-box input {
      background: none; border: none; outline: none;
      color: #fff; font-size: 13px; flex: 1;
      padding: 8px 8px 8px 0;
      font-family: 'DM Sans', sans-serif;
    }
    .search-box input::placeholder { color: #4a2035; }
    .search-box button {
      background: var(--pink); border: none; color: #fff;
      font-size: 12px; font-weight: 600; padding: 6px 14px;
      border-radius: 6px; cursor: pointer; transition: background 0.2s;
    }
    .search-box button:hover { background: var(--pink-dark); }
    .btn-add {
      background: var(--pink); border: none; color: #fff;
      font-size: 12px; font-weight: 600; padding: 8px 16px;
      border-radius: 8px; cursor: pointer; transition: background 0.2s;
      text-decoration: none; display: inline-flex; align-items: center;
    }
    .btn-add:hover { background: var(--pink-dark); color: #fff; }
    .btn-nav {
      border: 1px solid var(--border);
      background: var(--surface2); color: var(--text);
      font-size: 12px; font-weight: 500; padding: 7px 14px;
      border-radius: 8px; cursor: pointer; text-decoration: none;
      transition: all 0.2s; display: inline-flex; align-items: center; gap: 6px;
    }
    .btn-nav:hover { border-color: rgba(220,80,140,0.4); color: #fff; }
    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 28px; letter-spacing: 2px;
      padding: 2rem 2rem 0.5rem; color: #fff;
    }
    .section-title span { color: var(--pink); }
    .movies-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px; padding: 0 2rem 3rem;
    }
    .movie-card {
      background: var(--surface); border-radius: 12px;
      overflow: hidden; position: relative;
      border: 1px solid var(--border);
      transition: transform 0.25s ease;
    }
    .movie-card:hover { transform: translateY(-6px); }
    .movie-card .poster { width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block; }
    .rating-badge {
      position: absolute; top: 10px; right: 10px;
      background: rgba(13,0,8,0.8);
      border-radius: 6px; padding: 4px 8px;
      font-size: 12px; font-weight: 600; color: var(--gold);
      display: flex; align-items: center; gap: 3px;
    }
    .fav-badge {
      position: absolute; top: 10px; left: 10px;
      background: rgba(13,0,8,0.7);
      border-radius: 6px; width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
      font-size: 15px; border: none; cursor: pointer;
      transition: transform 0.15s;
    }
    .fav-badge:hover { transform: scale(1.2); }
    .card-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(13,0,8,0.95) 0%, transparent 50%);
      opacity: 0; transition: opacity 0.25s;
      display: flex; align-items: flex-end; padding: 14px;
    }
    .movie-card:hover .card-overlay { opacity: 1; }
    .overlay-btn {
      background: var(--pink); color: #fff; border: none;
      border-radius: 7px; padding: 9px 0; font-size: 13px;
      font-weight: 600; font-family: 'DM Sans', sans-serif;
      cursor: pointer; text-decoration: none;
      width: 100%; text-align: center; display: block;
      transition: background 0.2s;
    }
    .overlay-btn:hover { background: var(--pink-dark); color: #fff; }
    .card-info { padding: 12px 14px 14px; }
    .card-title {
      font-weight: 600; font-size: 14px; color: #fff;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px;
    }
    .card-meta { display: flex; justify-content: space-between; align-items: center; }
    .card-year { font-size: 12px; color: var(--muted); }
    .new-tag { font-size: 11px; color: var(--pink); font-weight: 500; }
    form {
      max-width: 520px; margin: 2rem auto;
      padding: 28px 32px;
      background: var(--surface);
      border-radius: 16px;
      border: 1px solid var(--border);
    }
    form.bare {
  max-width: none;
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  box-shadow: none;
  border-radius: 0;
}
    .form-label { color: var(--muted); font-size: 12px; margin-bottom: 5px; letter-spacing: 0.5px; text-transform: uppercase; }
    .form-control {
      background: var(--bg);
      border: 1px solid var(--border);
      color: #fff; border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
    }
    .form-control:focus {
      background: var(--bg);
      border-color: var(--pink);
      color: #fff;
      box-shadow: 0 0 0 3px var(--pink-glow);
    }
    .form-control::placeholder { color: #3a1025; }
    h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 30px; letter-spacing: 2px;
      text-align: center; margin: 1.5rem 0 1rem; color: #fff;
    }
    .btn { border-radius: 8px; font-family: 'DM Sans', sans-serif; font-weight: 500; }
    .btn-primary { background: var(--pink) !important; border-color: var(--pink) !important; }
    .btn-primary:hover { background: var(--pink-dark) !important; border-color: var(--pink-dark) !important; }
    .btn-danger { background: #2a0010; border-color: #2a0010; color: #ff80a0; }
    .btn-danger:hover { background: #c93078; border-color: #c93078; color: #fff; }
    .btn-success { background: transparent; border: 1px solid var(--border); color: #c090b0; }
    .btn-success:hover { background: var(--surface2); color: #fff; }
    .show-card {
      max-width: 460px; margin: 2rem auto;
      background: var(--surface); border-radius: 16px;
      overflow: hidden; border: 1px solid var(--border);
    }
    .show-card img { width: 100%; max-height: 340px; object-fit: cover; }
    .show-body { padding: 20px; }
    .show-body h2 { text-align: left; margin: 0 0 4px; font-size: 26px; }
    .show-year { color: var(--muted); font-size: 13px; margin-bottom: 12px; }
    .show-desc { color: #b08098; font-size: 14px; line-height: 1.7; }
    .reviews-section {
      max-width: 460px; margin: 0 auto 3rem;
      background: var(--surface); border-radius: 16px;
      padding: 22px; border: 1px solid var(--border);
    }
    .reviews-section h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 22px; letter-spacing: 1px;
      margin-bottom: 18px; text-align: center; color: #fff;
    }
    .review-card {
      background: var(--bg); border-radius: 10px;
      padding: 12px 14px; margin-bottom: 10px;
      border: 1px solid var(--border);
    }
    .summary-card {
      max-width: 480px; margin: 2rem auto;
      background: var(--surface); border-radius: 16px;
      overflow: hidden; border: 1px solid var(--border);
    }
    .summary-card img { width: 100%; max-height: 400px; object-fit: cover; }
    .summary-body { padding: 22px; }
    .summary-body h4 { color: var(--pink); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; }
    .summary-body p { color: #b08098; font-size: 14px; line-height: 1.8; }
    .cast-pill {
      display: inline-block;
      background: var(--surface2); border: 1px solid var(--border);
      border-radius: 20px; padding: 4px 14px;
      font-size: 12px; color: var(--muted); margin: 3px;
    }
    /* starability styles kept same as before */
    .starability-result { position:relative;width:150px;height:30px;background-image:url("data:image/png;base64,");font-size:0.1em;color:transparent }
    .starability-result:after { content:' ';position:absolute;left:0;height:30px;background-image:url("data:image/png;base64,");background-position:0 -30px }
    .starability-result[data-rating="5"]::after{width:150px}.starability-result[data-rating="4"]::after{width:120px}.starability-result[data-rating="3"]::after{width:90px}.starability-result[data-rating="2"]::after{width:60px}.starability-result[data-rating="1"]::after{width:30px}
    .starability-basic{display:block;position:relative;width:150px;min-height:60px;padding:0;border:none}
    .starability-basic>input{position:absolute;margin-right:-100%;opacity:0}
    .starability-basic>input:checked~label,.starability-basic>input:focus~label{background-position:0 0}
    .starability-basic>input:checked+label,.starability-basic>input:focus+label{background-position:0 -30px}
    .starability-basic>input:not([disabled]):hover~label{background-position:0 0}
    .starability-basic>input:not([disabled]):hover+label{background-position:0 -30px}
    .starability-basic>input:not([disabled]):hover+label::before{opacity:1}
    .starability-basic>label{position:relative;display:inline-block;float:left;width:30px;height:30px;font-size:0.1em;color:transparent;cursor:pointer;background-image:url("data:image/png;base64,");background-repeat:no-repeat;background-position:0 -30px}
    .starability-basic>label::before{content:'';position:absolute;display:block;height:30px;background-image:url("data:image/png;base64,");background-position:0 30px;pointer-events:none;opacity:0}
    .starability-basic>label:nth-of-type(5)::before{width:120px;left:-120px}.starability-basic>label:nth-of-type(4)::before{width:90px;left:-90px}.starability-basic>label:nth-of-type(3)::before{width:60px;left:-60px}.starability-basic>label:nth-of-type(2)::before{width:30px;left:-30px}.starability-basic>label:nth-of-type(1)::before{width:0;left:0}
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg fixed-top">
    <div class="container-fluid gap-3">
      <a class="navbar-brand" href="/">
        <span class="brand-name">Movies ADDA</span>
        <span class="brand-sub">PREMIUM VAULT</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain" style="border-color:rgba(220,80,140,0.3);color:#c93078">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMain">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
          <li class="nav-item"><a class="nav-link" href="/trending">⭐ Top Rated</a></li>
          <li class="nav-item"><a class="nav-link" href="/">All Movies</a></li>
          <li class="nav-item"><a class="nav-link" href="/favorite">♥ Favorites</a></li>
        </ul>
        <div class="d-flex align-items-center gap-3">
          <form action="/search" class="search-box" role="search" style="margin:0;padding:0;background:none;box-shadow:none;border:1px solid rgba(220,80,140,0.2);">
            <input type="search" name="q" placeholder="Search movies, cast, year...">
            <button type="submit">Search</button>
          </form>
          <a href="/new" class="btn-add">+ ADD MOVIE</a>
        </div>
      </div>
    </div>
  </nav>
