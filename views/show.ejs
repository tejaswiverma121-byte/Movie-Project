<%- include('./header.ejs') -%>
<div class="show-card">
  <img src="<%=m.img%>" alt="<%=m.name%>">
  <div class="show-body">
    <h2><%=m.name%></h2>
    <p class="show-year"><%=m.year%></p>
    <p class="show-desc"><%=m.desc%></p>
    <div class="d-flex gap-2 mt-4 flex-wrap">
      <form action="/movie/delete/<%=m._id%>?_method=DELETE" method="POST" class="bare">
        <button class="btn btn-danger px-4">Delete</button>
      </form>
      <form action="/movie/edit/<%=m._id%>" method="GET" class="bare">
        <button class="btn btn-primary px-4">Edit</button>
      </form>
      <a class="btn btn-success px-4" href="/summary/<%=m._id%>">AI Summary</a>
    </div>
  </div>
</div>

<div class="reviews-section mt-3">
  <h1>Reviews</h1>
  <form action="/rating/<%=m._id%>" method="POST" style="background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:20px;max-width:100%;box-shadow:none;margin:0 0 20px;">
    <fieldset class="starability-basic mb-3">
      <legend class="form-label">Rating:</legend>
      <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
      <input type="radio" id="first-rate1" name="rating" value="1" /><label for="first-rate1" title="Terrible">1 star</label>
      <input type="radio" id="first-rate2" name="rating" value="2" /><label for="first-rate2" title="Not good">2 stars</label>
      <input type="radio" id="first-rate3" name="rating" value="3" /><label for="first-rate3" title="Average">3 stars</label>
      <input type="radio" id="first-rate4" name="rating" value="4" /><label for="first-rate4" title="Very good">4 stars</label>
      <input type="radio" id="first-rate5" name="rating" value="5" /><label for="first-rate5" title="Amazing">5 stars</label>
    </fieldset>
    <div class="mb-3">
      <label class="form-label">Comment</label>
      <textarea name="comment" rows="3" class="form-control" placeholder="Write your review..."></textarea>
    </div>
    <button class="btn btn-primary w-100" type="submit">Post Review</button>
  </form>

  <% for(let r of m.reviews){ %>
  <div class="review-card">
    <p class="starability-result" data-rating="<%=r.rating%>"></p>
    <div class="d-flex justify-content-between align-items-center mt-1">
      <p style="color:#c090b0;font-size:14px;margin:0;"><%=r.comment%></p>
      <form action="/review/delete/<%=m._id%>/<%=r._id%>" method="POST" class="bare">
        <button type="submit" style="background:none;border:none;color:#4a2035;cursor:pointer;font-size:16px;transition:color 0.2s" onmouseover="this.style.color='#c93078'" onmouseout="this.style.color='#4a2035'">🗑️</button>
      </form>
    </div>
  </div>
  <% } %>
</div>
<%- include('./footer.ejs') -%>