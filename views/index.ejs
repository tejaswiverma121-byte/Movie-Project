<%- include('./header.ejs') -%>
<p class="section-title">ALL <span>MOVIES</span></p>
<div class="movies-grid">
  <% for(let movie of allMovies){ %>
  <div class="movie-card">
    <img src="<%=movie.img%>" class="poster" alt="<%=movie.name%>">
    <% if(movie.avgRating > 0){ %>
    <div class="rating-badge">★ <%=movie.avgRating%></div>
    <% } %>
    <form action="/favorite/<%=movie._id%>" method="POST" class="bare">
      <button class="fav-badge"><%= movie.favorite ? "♥" : "♡" %></button>
    </form>
    <div class="card-overlay">
      <a href="/movies/<%=movie._id%>" class="overlay-btn">View Movie</a>
    </div>
    <div class="card-info">
      <div class="card-title"><%=movie.name%></div>
      <div class="card-meta">
        <span class="card-year"><%=movie.year%></span>
        <% if(movie.avgRating == 0){ %><span class="new-tag">New</span><% } %>
      </div>
    </div>
  </div>
  <% } %>
</div>
<%- include('./footer.ejs') -%>